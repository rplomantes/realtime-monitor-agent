## install required package
sudo apt update
sudo apt install git curl sysstat -y
sudo systemctl enable sysstat
sudo systemctl start sysstat

##Clone Your GitHub Repository
cd /opt
sudo git clone https://github.com/rplomantes/realtime-monitor-agent.git
cd realtime-monitor-agent


##change permission on build.sh
sudo chmod +x build.sh
sudo ./build.sh
## after build you should see
#build/realtime-monitor.deb#

## Install
sudo dpkg -i realtime-monitor.deb

## Configure
sudo nano /etc/monitor.conf

## Restart
sudo systemctl restart monitor

## Status
sudo systemctl status monitor

## Logs
journalctl -u monitor
